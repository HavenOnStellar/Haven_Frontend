# Haven Frontend Environment Variables
# Copy this file to .env.local and update with your values

# ============================================================================
# Stellar Network Configuration
# ============================================================================

# Network to connect to: "testnet" or "mainnet"
# For local development, use "testnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# ============================================================================
# Haven Contract Configuration
# ============================================================================

# The deployed Haven Registry Soroban contract ID
# This is a placeholder value - replace with your actual contract ID after deployment
# 
# To deploy and get your contract ID:
# 1. Deploy the Haven contract to testnet
# 2. Run: stellar contract bindings typescript --network testnet --contract-id <YOUR_CONTRACT_ID> --output-dir ./src/app/lib/haven-bindings
# 3. Update this value with your contract ID
NEXT_PUBLIC_HAVEN_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# ============================================================================
# Development Notes
# ============================================================================
#
# Safe defaults for local testnet development:
# - NEXT_PUBLIC_STELLAR_NETWORK=testnet
# - Use the Stellar testnet faucet to fund test accounts: https://laboratory.stellar.org/#account-creator
# - Connect with Freighter wallet in testnet mode
# - Contract ID will be provided after deploying the Haven contract to testnet
#
# For production deployment:
# - NEXT_PUBLIC_STELLAR_NETWORK=mainnet
# - Deploy contract to mainnet and update NEXT_PUBLIC_HAVEN_CONTRACT_ID
# - Ensure Freighter is configured for mainnet
